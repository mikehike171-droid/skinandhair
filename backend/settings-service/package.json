{
  "name": "hims-settings-service",
  "version": "1.0.0",
  "description": "HIMS Settings Microservice",
  "scripts": {
    "build": "node \"node_modules/@nestjs/cli/bin/nest.js\" build",
    "start": "node \"node_modules/@nestjs/cli/bin/nest.js\" start",
    "start:dev": "node ./node_modules/concurrently/dist/bin/concurrently.js \"node ./node_modules/typescript/bin/tsc -w\" \"node --watch dist/main.js\"",
    "start:prod": "node dist/main"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^10.0.0",
